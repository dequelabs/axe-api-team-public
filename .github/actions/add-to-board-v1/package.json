{
  "name": "add-to-board-v1",
  "version": "1.0.0",
  "description": "A GitHub Action to move issues to a specific column on a project board",
  "bugs": {
    "url": "https://github.com/dequelabs/axe-api-team-public/issues"
  },
  "homepage": "https://github.com/dequelabs/axe-api-team-public#readme",
  "license": "MPL-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dequelabs/axe-api-team-public.git"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "node ../../../scripts/build-action.mjs",
    "test": "node --import tsx --experimental-test-module-mocks --test --test-reporter=spec --test-force-exit 'src/**/*.test.ts'",
    "coverage": "node --import tsx --experimental-test-module-mocks --experimental-test-coverage --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 --test-coverage-include='src/**/*.ts' --test-coverage-exclude='src/**/*.test.ts' --test-coverage-exclude='src/index.ts' --test --test-reporter=spec --test-force-exit 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write \"src/**/*.{js,ts,tsx,json,md,css,html}\"",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\""
  }
}
